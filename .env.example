# Auris: Complete Environment Configuration

# =============================================================================
# APP CONFIGURATION
# =============================================================================
PROJECT_NAME=Auris
VERSION=0.1.0
DEBUG=true

# =============================================================================
# AUTH0 CONFIGURATION
# =============================================================================
# Get these from your Auth0 Dashboard (Applications > Settings)
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_API_AUDIENCE=https://auris-api
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_ALGORITHMS=RS256

# =============================================================================
# SNOWFLAKE CONFIGURATION
# =============================================================================
SNOWFLAKE_USER=your-snowflake-username
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_ACCOUNT=your-account-id
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=AURIS_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN

# =============================================================================
# TWILIO CONFIGURATION (SMS Notifications)
# =============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# SMARTSPECTRA SDK (Presage Technologies)
# =============================================================================
SMARTSPECTRA_API_KEY=your-smartspectra-api-key

# =============================================================================
# URL CONFIGURATION
# =============================================================================
# Backend
API_URL=http://localhost:8000
API_V1_STR=/api/v1

# Frontend
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:8000

# Dashboard
DASHBOARD_URL=http://localhost:8501

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_HOSTS=["http://localhost:3000","http://localhost:8501","http://localhost:8000"]

# =============================================================================
# FRONTEND ENV (REACT)
# =============================================================================
REACT_APP_AUTH0_DOMAIN=${AUTH0_DOMAIN}
REACT_APP_AUTH0_CLIENT_ID=${AUTH0_CLIENT_ID}
REACT_APP_AUTH0_AUDIENCE=${AUTH0_API_AUDIENCE}
REACT_APP_SMARTSPECTRA_API_KEY=${SMARTSPECTRA_API_KEY}
