<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Session Notes"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvNotesPatient"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_gray"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notes"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etNotes"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/input_field_background"
        android:padding="12dp"
        android:gravity="top|start"
        android:hint="Write your clinical observations, treatment notes, follow-up actions…"
        android:textSize="14sp"
        android:textColor="@color/text_dark"
        android:textColorHint="@color/text_muted"
        android:inputType="textMultiLine"
        android:layout_marginBottom="14dp" />

    <TextView
        android:id="@+id/tvSavedTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_muted"
        android:textStyle="italic"
        android:visibility="gone"
        android:layout_marginBottom="14dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Cancel"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:paddingHorizontal="16dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Save Notes"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/button_add_notes"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
