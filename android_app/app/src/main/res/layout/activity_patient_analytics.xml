<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB"
    tools:context=".PatientAnalyticsActivity">

    <!-- Top bar with gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_background"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="16dp">

        <!-- Back button + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_back_arrow"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/analytics_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Patient info in header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/avatar_placeholder"
                android:contentDescription="Patient"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvHeaderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHeaderBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Severe"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@drawable/badge_severe" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Discrepancy alert banner -->
            <LinearLayout
                android:id="@+id/alertBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/alert_discrepancy_background"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_warning_amber"
                    android:contentDescription="Warning"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAlertTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#92400E" />

                    <TextView
                        android:id="@+id/tvAlertBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#B45309" />
                </LinearLayout>
            </LinearLayout>

            <!-- Score Summary Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/chart_card_background"
                android:padding="20dp"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvSummaryType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHQ-9 (Depression)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSummaryScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11 / 27"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/icon_teal"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSummarySeverity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moderate"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvSummaryPrev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_gray"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvSummaryTrend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Vitals Chart Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/chart_card_background"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analytics_vitals_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="14dp" />

                <!-- Tabs: Heart Rate / Respiratory Rate -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tabHeartRate"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="@string/analytics_tab_heart_rate"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/icon_teal"
                        android:background="@drawable/tab_active"
                        android:paddingHorizontal="16dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tabRespRate"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="@string/analytics_tab_resp_rate"
                        android:textSize="13sp"
                        android:textColor="@color/text_gray"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Chart view -->
                <com.example.cadence.VitalsChartView
                    android:id="@+id/vitalsChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvNormalRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analytics_normal_hr"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Screening Breakdown Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/screening_section_background"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvScreeningTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/analytics_phq9_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />

                    <TextView
                        android:id="@+id/tvScoreBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="11/27"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/score_circle_teal"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp" />
                </LinearLayout>

                <!-- Questions container - populated programmatically -->
                <LinearLayout
                    android:id="@+id/questionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- AI-Generated Clinical Insights Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/insights_card_background"
                android:elevation="2dp"
                android:layout_marginBottom="16dp"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_title"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="16dp" />

                <!-- Key Findings header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_key_findings"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="@color/text_gray"
                    android:layout_marginBottom="10dp" />

                <!-- Key findings container - populated programmatically -->
                <LinearLayout
                    android:id="@+id/keyFindingsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp" />

                <!-- Discussion Points header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_discussion_points"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="@color/text_gray"
                    android:layout_marginBottom="10dp" />

                <!-- Discussion points container - populated programmatically -->
                <LinearLayout
                    android:id="@+id/discussionPointsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="18dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="14dp" />

                <!-- Disclaimer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_disclaimer"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="italic"
                    android:layout_marginBottom="16dp" />

                <!-- Export PDF button -->
                <LinearLayout
                    android:id="@+id/btnExportPdf"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/button_export"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_export"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Export" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_export_pdf"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />
                </LinearLayout>

                <!-- Add Session Notes button -->
                <LinearLayout
                    android:id="@+id/btnAddNotes"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/button_add_notes"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_add"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Add" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_add_notes"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
