<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/patient_card_background"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="14dp"
    android:padding="16dp"
    android:elevation="2dp">

    <!-- Top row: avatar, name/date, severity badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/avatar_placeholder"
            android:contentDescription="Patient avatar"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPatientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:id="@+id/tvPatientDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jan 15, 2025 • 2:30 PM"
                android:textSize="12sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSeverityBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Critical"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/badge_critical" />
    </LinearLayout>

    <!-- Score box - horizontal layout for better space usage -->
    <LinearLayout
        android:id="@+id/scoreBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/score_box_background"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvScoreLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/plist_phq9_score"
                android:textSize="12sp"
                android:textColor="@color/text_gray"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvScoreValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/icon_teal" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSeverityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moderate"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="@drawable/badge_moderate" />
    </LinearLayout>

    <!-- View Analytics button -->
    <LinearLayout
        android:id="@+id/btnViewAnalytics"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/button_analytics"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_analytics"
            android:tint="@color/white"
            android:layout_marginEnd="6dp"
            android:contentDescription="Analytics" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/plist_view_analytics"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/white" />
    </LinearLayout>

</LinearLayout>
