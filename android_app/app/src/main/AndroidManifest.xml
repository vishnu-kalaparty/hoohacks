<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.cadence">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-feature android:name="android.hardware.camera" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cadence">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".CameraTestActivity"
            android:exported="false" />
        <activity
            android:name=".TherapistPatientsActivity"
            android:exported="false" />
        <activity
            android:name=".SimilarSessionsActivity"
            android:exported="false" />
        <activity
            android:name=".SessionDetailActivity"
            android:exported="false" />

        <!-- Register the SDK's camera activity with a Material Components theme -->
        <activity
            android:name="com.presagetech.smartspectra.ui.SmartSpectraActivity"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"
            android:exported="false"
            tools:replace="android:theme" />
    </application>

</manifest>